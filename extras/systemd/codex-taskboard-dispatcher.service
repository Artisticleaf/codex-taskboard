[Unit]
Description=codex-taskboard dispatcher loop
After=network.target

[Service]
Type=simple
User=ubunut
Group=ubunut
WorkingDirectory=/home/Awei/codex-taskboard
Environment=CODEX_TASKBOARD_HOME=/home/ubunut/.local/state/codex-taskboard
Environment=CODEX_HOME=/home/ubunut/.codex
Environment=CODEX_BIN=/usr/local/bin/codex
Environment=TMUX_BIN=/usr/bin/tmux
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/Awei/codex-taskboard/.venv/bin/codex-taskboard service run dispatcher --mode gpu-fill --gpu-count 4 --cpu-thread-limit 40 --poll-seconds 5
Restart=always
RestartSec=3
RestartPreventExitStatus=3
KillMode=process

[Install]
WantedBy=multi-user.target
